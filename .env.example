POSTHOG_API_KEY=
GEMINI_API_KEY=
SECRET_KEY=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
NYT_API_KEY=
NYT_API_SECRET=
GOOGLE_BOOKS_API_KEY=

# Environment + debug.
#
# DEBUG defaults to False. Django refuses to boot with DEBUG=True unless
# DJANGO_ENV is one of {development, test, ci}. Set both explicitly for
# local dev; set DJANGO_ENV=production (and leave DEBUG unset or False)
# in production.
DJANGO_ENV=development
DEBUG=True

# Optional if you are running without docker
# DATABASE_URL=postgres://bibliotype_user:yoursecurepassword123@127.0.0.1:5432/bibliotype_db

# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Set to True to enable Django Silk profiling at /silk/ (local development only).
# Off by default to avoid the runtime overhead and DB writes Silk does on every request.
# ENABLE_SILK=True